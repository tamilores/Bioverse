generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Questionnaires {
    id      Int         @id @default(autoincrement())
    name    String
    
    junctions Junction[]
}

model Questions {
    id           Int         @id @default(autoincrement())
    question     String
    
    junctions    Junction[]
    responses    Responses[]
}

model Junction {
    id                  Int         @id @default(autoincrement())
    questionnaireId     Int
    questionId          Int

    questionnaire       Questionnaires    @relation(fields: [questionnaireId], references: [id])    
    question            Questions         @relation(fields: [questionId], references: [id])
}

model User {
  id                Int        @id @default(autoincrement())
  username          String     @unique
  password          String
  isAdmin           Boolean    @default(false)
  questionCount     Int        @default(0)
  responses         Responses[]
}

model Responses {
  id            Int         @id @default(autoincrement())
  userId        Int    
  questionId    Int
  answer        String[]

  user          User        @relation(fields: [userId], references: [id])
  question      Questions   @relation(fields: [questionId], references: [id])
}